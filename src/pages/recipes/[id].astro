---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { REGION_LABELS, MEAL_LABELS, DIFFICULTY_LABELS } from '../../content.config';

export async function getStaticPaths() {
  const recipes = await getCollection('recipes');
  return recipes.map((recipe) => ({
    params: { id: recipe.id },
    props: { recipe },
  }));
}

const { recipe } = Astro.props;
const { Content } = await render(recipe);
const data = recipe.data;
const totalTime = data.prepTime + data.cookTime;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title={`${data.title} — FoodVN`} description={data.description}>
  <article class="recipe-content mx-auto max-w-4xl px-4 py-10 sm:px-6" data-pagefind-body>
    <!-- Breadcrumb -->
    <nav class="no-print mb-6 flex items-center gap-2 text-sm text-stone-500">
      <a href={`${base}/`} class="hover:text-brand-600">Trang chủ</a>
      <span>/</span>
      <a href={`${base}/mien/${data.region}`} class="hover:text-brand-600">
        {REGION_LABELS[data.region]}
      </a>
      <span>/</span>
      <span class="text-stone-700 dark:text-stone-300">{data.title}</span>
    </nav>

    <!-- Header -->
    <header class="mb-10">
      <div class="mb-3 flex flex-wrap gap-2">
        <span class="inline-flex items-center rounded-full bg-brand-100 px-3 py-1 text-xs font-medium text-brand-800 dark:bg-brand-900/40 dark:text-brand-200">
          {REGION_LABELS[data.region]}
        </span>
        <span class="inline-flex items-center rounded-full bg-stone-100 px-3 py-1 text-xs font-medium text-stone-700 dark:bg-stone-800 dark:text-stone-300">
          {MEAL_LABELS[data.meal]}
        </span>
        <span class="inline-flex items-center rounded-full bg-emerald-100 px-3 py-1 text-xs font-medium text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-200">
          Độ khó: {DIFFICULTY_LABELS[data.difficulty]}
        </span>
      </div>
      <h1 class="font-display text-4xl font-bold leading-tight text-stone-900 sm:text-5xl dark:text-stone-100">
        {data.title}
      </h1>
      <p class="mt-4 text-lg text-stone-600 dark:text-stone-400">{data.description}</p>

      <!-- Meta info -->
      <div class="mt-6 grid grid-cols-2 gap-4 rounded-2xl border border-stone-200 bg-white p-5 text-sm sm:grid-cols-4 dark:border-stone-800 dark:bg-stone-900">
        <div>
          <p class="text-xs text-stone-500">Sơ chế</p>
          <p class="mt-1 font-semibold">{data.prepTime} phút</p>
        </div>
        <div>
          <p class="text-xs text-stone-500">Nấu</p>
          <p class="mt-1 font-semibold">{data.cookTime} phút</p>
        </div>
        <div>
          <p class="text-xs text-stone-500">Tổng</p>
          <p class="mt-1 font-semibold text-brand-600 dark:text-brand-400">{totalTime} phút</p>
        </div>
        <div>
          <p class="text-xs text-stone-500">Khẩu phần</p>
          <p class="mt-1 font-semibold">{data.servings} người</p>
        </div>
      </div>

      <!-- Print button -->
      <div class="no-print mt-4 flex flex-wrap gap-3">
        <button
          onclick="window.print()"
          class="inline-flex items-center gap-2 rounded-full border border-stone-300 bg-white px-4 py-2 text-sm font-medium text-stone-700 transition hover:border-brand-400 hover:bg-brand-50 dark:border-stone-700 dark:bg-stone-900 dark:text-stone-200 dark:hover:bg-stone-800"
        >
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 9V2h12v7M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2M6 14h12v8H6z" />
          </svg>
          In công thức
        </button>
      </div>
    </header>

    <!-- Description (markdown body) -->
    <div class="prose prose-stone mb-10 max-w-none text-stone-700 dark:prose-invert dark:text-stone-300">
      <Content />
    </div>

    <!-- Ingredients -->
    <section class="mb-10">
      <h2 class="mb-4 font-display text-2xl font-bold text-stone-900 dark:text-stone-100">
        Nguyên liệu <span class="text-base font-normal text-stone-500">({data.servings} người ăn)</span>
      </h2>
      <ul class="space-y-2 rounded-2xl border border-stone-200 bg-white p-6 dark:border-stone-800 dark:bg-stone-900">
        {data.ingredients.map((ing) => (
          <li class="ingredient-card flex items-start justify-between gap-4 border-b border-stone-100 pb-2 last:border-0 last:pb-0 dark:border-stone-800">
            <span class="text-stone-800 dark:text-stone-200">{ing.name}</span>
            <span class="text-right text-stone-600 dark:text-stone-400">{ing.quantity}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- Steps -->
    <section class="mb-10">
      <h2 class="mb-4 font-display text-2xl font-bold text-stone-900 dark:text-stone-100">
        Cách làm
      </h2>
      <ol class="space-y-4">
        {data.steps.map((step, i) => (
          <li class="step-card flex gap-4 rounded-2xl border border-stone-200 bg-white p-5 dark:border-stone-800 dark:bg-stone-900">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-brand-600 font-bold text-white">
              {i + 1}
            </span>
            <p class="pt-1 text-stone-700 dark:text-stone-300">{step}</p>
          </li>
        ))}
      </ol>
    </section>

    <!-- Tips -->
    {data.tips && (
      <section class="mb-10 rounded-2xl border-l-4 border-brand-500 bg-brand-50 p-6 dark:bg-brand-950/30">
        <h3 class="mb-2 flex items-center gap-2 font-display text-xl font-bold text-brand-900 dark:text-brand-200">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" d="M12 2l2.4 7.4H22l-6 4.6 2.3 7.4-6.3-4.6L5.7 21l2.3-7.4-6-4.6h7.6L12 2z" />
          </svg>
          Mẹo bếp
        </h3>
        <p class="text-stone-700 dark:text-stone-300">{data.tips}</p>
      </section>
    )}

    {data.tags.length > 0 && (
      <div class="no-print flex flex-wrap gap-2">
        {data.tags.map((tag) => (
          <span class="rounded-full bg-stone-100 px-3 py-1 text-xs text-stone-600 dark:bg-stone-800 dark:text-stone-400">
            #{tag}
          </span>
        ))}
      </div>
    )}
  </article>
</BaseLayout>
