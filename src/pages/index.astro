---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import RecipeCard from '../components/RecipeCard.astro';
import { REGION_LABELS, MEAL_LABELS } from '../content.config';
import { heroImageUrl, recipeImageUrl, regionImageUrl } from '../utils/images';

const recipes = await getCollection('recipes');
const featured = recipes.filter((r) => r.data.featured);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const byRegion = {
  bac: recipes.filter((r) => r.data.region === 'bac'),
  trung: recipes.filter((r) => r.data.region === 'trung'),
  nam: recipes.filter((r) => r.data.region === 'nam'),
};

const meals: Array<keyof typeof MEAL_LABELS> = ['sang', 'trua', 'toi', 'trang-mieng', 'an-vat'];

const heroImage = heroImageUrl();
const regionImages = {
  bac: regionImageUrl('bac'),
  trung: regionImageUrl('trung'),
  nam: regionImageUrl('nam'),
};
---

<BaseLayout title="FoodVN — Cẩm nang món ăn Việt Nam">
  <!-- Hero with banner image -->
  <section class="relative isolate overflow-hidden">
    <img
      src={heroImage}
      alt="Cẩm nang ẩm thực Việt Nam"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      class="absolute inset-0 -z-10 h-full w-full object-cover"
    />
    <!-- Overlay tối để chữ rõ trên ảnh -->
    <div class="absolute inset-0 -z-10 bg-gradient-to-r from-stone-950/85 via-stone-950/65 to-stone-950/30"></div>

    <div class="mx-auto max-w-6xl px-4 py-24 sm:px-6 sm:py-32 lg:py-40">
      <div class="max-w-2xl text-white">
        <p class="mb-3 text-sm font-medium uppercase tracking-widest text-brand-300">
          Cẩm nang ẩm thực Việt
        </p>
        <h1 class="font-display text-5xl font-bold leading-tight drop-shadow-2xl sm:text-6xl lg:text-7xl">
          Hương vị <span class="text-brand-400">ba miền</span><br />trong căn bếp của bạn
        </h1>
        <p class="mt-6 max-w-xl text-lg text-stone-200 drop-shadow sm:text-xl">
          {recipes.length} công thức món ăn Việt Nam được biên soạn cẩn thận — từ phở Hà Nội,
          bún bò Huế đến cơm tấm Sài Gòn. Đầy đủ nguyên liệu, từng bước và mẹo bếp.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href={`${base}/search`}
            class="inline-flex items-center gap-2 rounded-full bg-brand-600 px-6 py-3 font-medium text-white shadow-lg shadow-brand-600/30 transition hover:bg-brand-700"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <circle cx="11" cy="11" r="7" />
              <path stroke-linecap="round" d="M21 21l-4.35-4.35" />
            </svg>
            Tìm món ăn
          </a>
          <a
            href="#kham-pha"
            class="inline-flex items-center gap-2 rounded-full border border-white/30 bg-white/10 px-6 py-3 font-medium text-white backdrop-blur transition hover:bg-white/20"
          >
            Khám phá ba miền
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured -->
  {featured.length > 0 && (
    <section class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
      <div class="mb-8 flex items-end justify-between">
        <div>
          <p class="text-sm font-medium uppercase tracking-widest text-brand-600 dark:text-brand-400">Nổi bật</p>
          <h2 class="font-display text-3xl font-bold text-stone-900 sm:text-4xl dark:text-stone-100">
            Món tinh hoa nhất định phải thử
          </h2>
        </div>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {featured.map((recipe, i) => (
          <RecipeCard
            href={`${base}/recipes/${recipe.id}`}
            title={recipe.data.title}
            description={recipe.data.description}
            region={recipe.data.region}
            meal={recipe.data.meal}
            difficulty={recipe.data.difficulty}
            prepTime={recipe.data.prepTime}
            cookTime={recipe.data.cookTime}
            image={recipeImageUrl(recipe, { width: 800, height: 500 })}
            eager={i < 3}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Browse by region -->
  <section id="kham-pha" class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <p class="text-sm font-medium uppercase tracking-widest text-brand-600 dark:text-brand-400">Theo vùng miền</p>
    <h2 class="mb-8 font-display text-3xl font-bold text-stone-900 sm:text-4xl dark:text-stone-100">
      Mỗi miền, một bản sắc
    </h2>

    <div class="grid gap-4 sm:grid-cols-3">
      {(['bac', 'trung', 'nam'] as const).map((region) => (
        <a
          href={`${base}/mien/${region}`}
          class="group relative aspect-[4/5] overflow-hidden rounded-2xl shadow-lg transition hover:-translate-y-1 hover:shadow-2xl"
        >
          <img
            src={regionImages[region]}
            alt={REGION_LABELS[region]}
            loading="lazy"
            decoding="async"
            class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-110"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-stone-950 via-stone-950/40 to-transparent"></div>
          <div class="absolute inset-0 flex flex-col justify-end p-6 text-white">
            <p class="text-sm uppercase tracking-widest opacity-80">{byRegion[region].length} công thức</p>
            <h3 class="mt-1 font-display text-3xl font-bold drop-shadow-lg">{REGION_LABELS[region]}</h3>
            <p class="mt-2 text-sm opacity-90">
              {region === 'bac' && 'Tinh tế, thanh tao với nước dùng trong.'}
              {region === 'trung' && 'Đậm đà, cay nồng — đặc sản Huế, Đà Nẵng.'}
              {region === 'nam' && 'Ngọt béo, đa dạng — đậm chất miền Tây.'}
            </p>
            <span class="mt-3 inline-flex w-fit items-center gap-1 text-sm font-medium text-brand-300 transition group-hover:gap-2">
              Xem món <span aria-hidden>→</span>
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Browse by meal -->
  <section class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <p class="text-sm font-medium uppercase tracking-widest text-brand-600 dark:text-brand-400">Theo bữa ăn</p>
    <h2 class="mb-8 font-display text-3xl font-bold text-stone-900 sm:text-4xl dark:text-stone-100">
      Bạn đang cần nấu cho bữa nào?
    </h2>
    <div class="flex flex-wrap gap-3">
      {meals.map((meal) => {
        const count = recipes.filter((r) => r.data.meal === meal).length;
        return (
          <a
            href={`${base}/bua/${meal}`}
            class="inline-flex items-center gap-2 rounded-full border border-stone-300 bg-white px-5 py-2.5 font-medium text-stone-800 transition hover:border-brand-400 hover:bg-brand-50 dark:border-stone-700 dark:bg-stone-900 dark:text-stone-100 dark:hover:bg-stone-800"
          >
            {MEAL_LABELS[meal]}
            <span class="rounded-full bg-stone-100 px-2 py-0.5 text-xs text-stone-600 dark:bg-stone-800 dark:text-stone-400">
              {count}
            </span>
          </a>
        );
      })}
    </div>
  </section>

  <!-- All recipes -->
  <section class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <h2 class="mb-8 font-display text-3xl font-bold text-stone-900 sm:text-4xl dark:text-stone-100">
      Tất cả công thức
    </h2>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {recipes.map((recipe) => (
        <RecipeCard
          href={`${base}/recipes/${recipe.id}`}
          title={recipe.data.title}
          description={recipe.data.description}
          region={recipe.data.region}
          meal={recipe.data.meal}
          difficulty={recipe.data.difficulty}
          prepTime={recipe.data.prepTime}
          cookTime={recipe.data.cookTime}
          image={recipeImageUrl(recipe, { width: 800, height: 500 })}
        />
      ))}
    </div>
  </section>
</BaseLayout>
