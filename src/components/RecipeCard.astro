---
import { REGION_LABELS, MEAL_LABELS, DIFFICULTY_LABELS } from '../content.config';

interface Props {
  href: string;
  title: string;
  description: string;
  region: string;
  meal: string;
  difficulty: string;
  prepTime: number;
  cookTime: number;
  image: string;
  eager?: boolean;
}

const {
  href,
  title,
  description,
  region,
  meal,
  difficulty,
  prepTime,
  cookTime,
  image,
  eager = false,
} = Astro.props;
const totalTime = prepTime + cookTime;
---

<a
  href={href}
  class="group flex h-full flex-col overflow-hidden rounded-2xl border border-stone-200 bg-white shadow-sm transition hover:-translate-y-1 hover:border-brand-400 hover:shadow-lg dark:border-stone-800 dark:bg-stone-900"
>
  <div class="relative aspect-[5/3] overflow-hidden bg-gradient-to-br from-brand-200 via-amber-200 to-rose-200 dark:from-brand-900 dark:via-amber-900 dark:to-rose-900">
    <img
      src={image}
      alt={title}
      loading={eager ? 'eager' : 'lazy'}
      decoding="async"
      class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
    />
  </div>
  <div class="flex flex-1 flex-col p-5">
    <div class="mb-2 flex flex-wrap gap-1.5">
      <span class="inline-flex items-center rounded-full bg-brand-100 px-2 py-0.5 text-xs font-medium text-brand-800 dark:bg-brand-900/40 dark:text-brand-200">
        {REGION_LABELS[region]}
      </span>
      <span class="inline-flex items-center rounded-full bg-stone-100 px-2 py-0.5 text-xs font-medium text-stone-700 dark:bg-stone-800 dark:text-stone-300">
        {MEAL_LABELS[meal]}
      </span>
    </div>
    <h3 class="font-display text-xl font-bold leading-tight text-stone-900 transition group-hover:text-brand-600 dark:text-stone-100">
      {title}
    </h3>
    <p class="mt-2 line-clamp-2 text-sm text-stone-600 dark:text-stone-400">{description}</p>
    <div class="mt-auto flex items-center gap-4 pt-4 text-xs text-stone-500 dark:text-stone-400">
      <span class="inline-flex items-center gap-1">
        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="10" />
          <path stroke-linecap="round" d="M12 6v6l4 2" />
        </svg>
        {totalTime} phút
      </span>
      <span class="inline-flex items-center gap-1">
        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
        {DIFFICULTY_LABELS[difficulty]}
      </span>
    </div>
  </div>
</a>
